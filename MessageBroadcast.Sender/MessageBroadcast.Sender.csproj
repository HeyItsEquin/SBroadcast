<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <OutputPath>..\Release</OutputPath>
  </PropertyGroup>

	<PropertyGroup>
		<ApplicationIcon>..\Assets\app.ico</ApplicationIcon>
		<ApplicationManifest>app.manifest</ApplicationManifest>
	</PropertyGroup>

	<ItemGroup>
	  <None Remove="Fonts\fa-solid-900.ttf" />
	</ItemGroup>

	<ItemGroup>
		<None Include="..\Assets\app.ico" Link="Assets\app.ico">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="WPF-UI" Version="4.2.1" />
	</ItemGroup>
	
  <ItemGroup>
    <ProjectReference Include="..\MessageBroadcast.Core\MessageBroadcast.Core.csproj" />
  </ItemGroup>
	
  <ItemGroup>
    <Folder Include="UI\" />
  </ItemGroup>
	
  <ItemGroup>
    <Resource Include="Fonts\fa-solid-900.ttf" />
  </ItemGroup>

</Project>
